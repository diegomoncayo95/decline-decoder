# Required
ANTHROPIC_API_KEY=your-anthropic-api-key-here
PORT=8080

# Optional — PostgreSQL (Aurora) connection
# If not set, the server runs in MOCK MODE with demo data
DB_HOST=database-1-instance-1.xxxxx.us-west-2.rds.amazonaws.com
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-db-password
DB_NAME=decline_decoder
DB_SSL=true
